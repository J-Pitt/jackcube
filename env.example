# JackCube environment variables
# Copy to .env.local for local dev. Set same vars in AWS Amplify console for production.

# —— Required: Upstash Redis (rooms) ——
# JackCube uses Redis key prefix "jackcube:" (can share an Upstash DB with other apps)
UPSTASH_REDIS_REST_URL=https://obliging-albacore-53641.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-from-upstash-console

# —— Required in production: public app URL ——
# Used for QR codes and /join invite links
# NEXT_PUBLIC_APP_URL=https://your-amplify-domain.amplifyapp.com

# —— Adult games lobby password (server-only) ——
# Default in dev if unset: cube18
# ADULT_GAMES_PASSWORD=your-secret-password
